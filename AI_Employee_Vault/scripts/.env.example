# Gold Tier Environment Configuration
# Personal AI FTEs Project
# 
# Copy this file to .env and update with your actual credentials
# NEVER commit .env to version control!

# ===========================================
# Facebook API Configuration (for Facebook MCP Server)
# ===========================================
# Get these from Meta Developer Dashboard: https://developers.facebook.com/
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# ===========================================
# Odoo ERP Configuration (for Odoo MCP Server)
# ===========================================
# Default Docker Compose settings
ODOO_URL=http://localhost:8069
ODOO_DB=postgres
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# ===========================================
# Vault Configuration (for Watchers)
# ===========================================
VAULT_PATH=D:/Personal-AI-FTEs/AI_Employee_Vault

# Watcher check intervals (in seconds)
FACEBOOK_CHECK_INTERVAL=120
ODOO_CHECK_INTERVAL=300

# ===========================================
# Ralph Wiggum Loop Configuration
# ===========================================
MAX_ITERATIONS=10
CLAUDE_TIMEOUT=300

# ===========================================
# Audit Logger Configuration
# ===========================================
LOG_RETENTION_DAYS=90
ENABLE_CONSOLE_LOGGING=true

# ===========================================
# Email Configuration (for Email MCP Server)
# ===========================================
# Add your Gmail/SMTP credentials here if needed
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost

# ===========================================
# LinkedIn Configuration (for LinkedIn Poster)
# ===========================================
# Add your LinkedIn API credentials here if needed
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# ===========================================
# Security Notes
# ===========================================
# 1. Change default Odoo password immediately after setup
# 2. Use long-lived access tokens for production
# 3. Rotate credentials every 90 days
# 4. Never commit .env to Git
# 5. Use separate app accounts for development

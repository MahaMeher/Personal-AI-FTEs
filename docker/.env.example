# Docker Compose Environment Variables
# Copy this file to .env and update with your values

# Odoo Configuration
ODOO_VERSION=19.0
ODOO_ADMIN_PASSWORD=odoo_secure_admin_password_123
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=odoo_secure_password_123
ODOO_DB_NAME=postgres

# Database Configuration
POSTGRES_VERSION=15
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo_secure_password_123

# Redis Configuration
REDIS_VERSION=7-alpine

# Facebook API Configuration (for Facebook MCP Server)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# Odoo MCP Server Configuration
ODOO_URL=http://localhost:8069
ODOO_DB=postgres
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# Docker Network
DOCKER_NETWORK_SUBNET=172.28.0.0/16

# Security - Change these in production!
SECRET_KEY=change_this_to_a_secure_random_string_in_production
